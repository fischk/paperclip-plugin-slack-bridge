{
  "name": "paperclip-plugin-slack-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "Deterministic Slack notifications and human-in-the-loop controls for Paperclip companies, over Slack Socket Mode.",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && node scripts/check-manifest-contract.mjs",
    "prepublishOnly": "npm run verify"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "files": [
    "dist/",
    "slack-app-manifest.socket-mode.json",
    "slack-app-manifest.socket-mode.yaml"
  ],
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "plugin",
    "slack",
    "notifications",
    "block-kit",
    "socket-mode",
    "human-in-the-loop"
  ],
  "author": "Karl Fischer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fischk/paperclip-plugin-slack-bridge.git"
  },
  "homepage": "https://github.com/fischk/paperclip-plugin-slack-bridge#readme",
  "bugs": {
    "url": "https://github.com/fischk/paperclip-plugin-slack-bridge/issues"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.618.0",
    "@paperclipai/shared": "^2026.618.0",
    "@types/node": "^26.1.0",
    "esbuild": "^0.27.3",
    "typescript": "^6.0.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.7"
  }
}
